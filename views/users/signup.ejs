<% layout("/layouts/boilerplate.ejs") %>

<div class="container-fluid min-vh-100 d-flex align-items-center justify-content-center bg-light">

  <div class="col-11 col-sm-9 col-md-6 col-lg-4" data-aos="fade-up">

    <div class="card border-0 shadow-lg p-4 login-card">

      <h3 class="text-center mb-3 fw-semibold">Create Your Account ✨</h3>
      <p class="text-center text-muted mb-4">Join Wanderlust and start exploring</p>

      <form action="/signup" method="post" class="needs-validation" novalidate>

        <!-- Username -->
        <div class="form-floating mb-3">
          <input 
            type="text"
            class="form-control"
            id="username"
            name="username"
            placeholder="Username"
            required>
          <label for="username">Username</label>
        </div>

        <!-- Email -->
        <div class="form-floating mb-3">
          <input 
            type="email"
            class="form-control"
            id="email"
            name="email"
            placeholder="Email"
            required>
          <label for="email">Email address</label>
        </div>

        <!-- Password -->
        <div class="form-floating mb-3">
          <input 
            type="password"
            class="form-control"
            id="password"
            name="password"
            placeholder="Password"
            required>
          <label for="password">Password</label>
        </div>

        <!-- Button -->
        <button class="btn btn-danger w-100 py-2 fw-semibold btn-modern">
          Sign Up
        </button>

        <!-- Login redirect -->
        <p class="text-center mt-4 mb-0 small">
          Already have an account?
          <a href="/login" class="text-decoration-none fw-semibold text-danger">
            Login
          </a>
        </p>

      </form>

    </div>

  </div>

</div>
