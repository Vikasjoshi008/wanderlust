<% layout("/layouts/boilerplate.ejs") %>

<div class="container py-3">

  <!-- ===== No Results ===== -->
  <% if (!listing || listing.length === 0) { %>
    <div class="alert alert-warning text-center">
      No listings matched your search.
    </div>
  <% } %>


  <% if (listing && listing.length > 0) { %>

    <% function chunk(arr, size) {
      let out = [];
      for (let i = 0; i < arr.length; i += size) {
        out.push(arr.slice(i, i + size));
      }
      return out;
    } %>


    <!-- ================= MOBILE (Spotify Style) ================= -->
    <div class="d-md-none">

      <% chunk(listing, 7).forEach(function(group){ %>

        <h6 class="fw-semibold mt-3 mb-2">Search Results</h6>

        <div class="d-flex overflow-auto gap-3 pb-2">

          <% group.forEach(function(list){ %>

            <a href="/listings/<%= list._id %>"
               class="text-decoration-none text-dark"
               style="flex: 0 0 48%;">

              <div class="card border-0 shadow-sm">

                <img src="<%= list.image.url %>"
                     class="card-img-top"
                     style="height:150px; object-fit:cover;"
                     alt="listing">

                <div class="card-body p-2">
                  <p class="fw-semibold mb-1"><%= list.title %></p>

                  <p class="mb-0">
                    ₹ <%= list.price.toLocaleString("en-IN") %>
                    <span class="text-muted small">/ night</span>
                  </p>
                </div>

              </div>

            </a>

          <% }) %>

        </div>

      <% }) %>

    </div>


    <!-- ================= DESKTOP GRID ================= -->
    <div class="row g-4 d-none d-md-flex">

      <% listing.forEach(function(list){ %>

        <div class="col-lg-4 col-md-6">

          <a href="/listings/<%= list._id %>"
             class="text-decoration-none text-dark">

            <div class="card border-0 shadow-sm h-100">

              <img src="<%= list.image.url %>"
                   class="card-img-top"
                   style="height:260px; object-fit:cover;"
                   alt="listing">

              <div class="card-body">
                <h6 class="fw-semibold mb-1"><%= list.title %></h6>

                <p class="mb-0">
                  ₹ <%= list.price.toLocaleString("en-IN") %>
                  <span class="text-muted small">/ night</span>
                </p>
              </div>

            </div>

          </a>

        </div>

      <% }) %>

    </div>

  <% } %>

</div>
