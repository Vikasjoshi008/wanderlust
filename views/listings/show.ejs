<% layout("/layouts/boilerplate.ejs") %>

<script>
  const maptoken = "<%= process.env.MAP_TOKEN %>";
  const listing = <%- JSON.stringify(listing) %>;
</script>

<div class="container py-4">

  <!-- ===== Title ===== -->
  <h2 class="fw-semibold mb-3"><%= listing.title %></h2>

  <!-- ===== Image ===== -->
  <div class="rounded-4 overflow-hidden shadow-sm mb-4">
    <img
      src="<%= listing.image.url %>"
      class="img-fluid w-100"
      style="max-height:420px; object-fit:cover;"
      alt="listing image">
  </div>

  <!-- ===== Details ===== -->
  <div class="row gy-3">

    <div class="col-lg-8">

      <p class="text-muted mb-1">
        Hosted by <strong><%= listing.owner.username %></strong>
      </p>

      <p class="mb-3"><%= listing.description %></p>

      <h5 class="fw-semibold">
        ₹ <%= listing.price.toLocaleString("en-IN") %>
        <span class="text-muted fs-6">for 2 nights</span>
      </h5>

      <p class="text-muted">
        <%= listing.location %>, <%= listing.country %>
      </p>

      <% if(curruser && listing.owner._id.equals(curruser._id)) { %>
        <div class="d-flex gap-2 mt-3">
          <a href="/listings/<%= listing._id %>/edit"
             class="btn btn-danger px-4">Edit</a>

          <form action="/listings/<%= listing._id %>?_method=DELETE" method="post">
            <button class="btn btn-outline-danger px-4">Delete</button>
          </form>
        </div>
      <% } %>

    </div>

  </div>

  <hr class="my-4">

  <!-- ===== Review Form ===== -->
  <% if(curruser) { %>
    <div class="bg-light p-4 rounded-4 mb-4">

      <h4 class="mb-3">Leave a review</h4>

      <form action="/listings/<%= listing._id %>/reviews"
            method="post"
            class="needs-validation"
            novalidate>

        <div class="mb-3">
          <label class="form-label">Rating</label>
          <fieldset class="starability-slot">
            <input type="radio" name="review[rating]" value="1" checked>
            <input type="radio" name="review[rating]" value="2">
            <input type="radio" name="review[rating]" value="3">
            <input type="radio" name="review[rating]" value="4">
            <input type="radio" name="review[rating]" value="5">
          </fieldset>
        </div>

        <div class="mb-3">
          <textarea
            name="review[comment]"
            class="form-control"
            rows="4"
            placeholder="Share your experience..."
            required></textarea>
        </div>

        <button class="btn btn-dark">Submit Review</button>

      </form>

    </div>
  <% } %>

  <!-- ===== Reviews ===== -->
  <% if(listing.reviews.length > 0) { %>
    <h4 class="mb-3">Reviews</h4>

    <div class="row">
      <% for (let review of listing.reviews) { %>

        <div class="col-md-6 mb-3">
          <div class="card border-0 shadow-sm h-100">
            <div class="card-body">

              <h6 class="fw-semibold mb-1">
                @<%= review.author.username %>
              </h6>

              <p class="starability-result mb-2"
                 data-rating="<%= review.rating %>"></p>

              <p class="text-muted"><%= review.comment %></p>

              <% if(curruser && review.author._id.equals(curruser._id)) { %>
                <form method="post"
                  action="/listings/<%= listing.id %>/reviews/<%= review.id %>?_method=DELETE">
                  <button class="btn btn-sm btn-outline-dark">
                    Delete
                  </button>
                </form>
              <% } %>

            </div>
          </div>
        </div>

      <% } %>
    </div>
  <% } %>

  <!-- ===== Map ===== -->
  <div class="rounded-4 overflow-hidden shadow-sm mt-4">
    <div id="map" style="width:100%; height:320px;"></div>
  </div>

</div>

<script src="/js/map.js"></script>
